{
  "name": "@course-anchor/eslint-config",
  "private": true,
  "type": "module",
  "exports": {
    "./base": "./base.ts",
    "./react-router": "./react-router.ts",
    "./react": "./react.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
